1..254 | ForEach-Object -Parallel {
    $ip = "00.000.0.$_"
    foreach ($port in 80,443) {
        try {
            $tcp = [System.Net.Sockets.TcpClient]::new()
            if ($tcp.ConnectAsync($ip, $port).Wait(200) -and $tcp.Connected) {
                "$ip : port $port OPEN"
            }
            $tcp.Dispose()
        } catch {}
    }
} -ThrottleLimit 50
